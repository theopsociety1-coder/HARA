{
  "expo": {
    "name": "HARA",
    "slug": "HARA",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hara",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hara.app",
      "config": {
        "googleMapsApiKey": "AIzaSyDemoKeyForTesting"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HARA needs your location to show nearby restaurants",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HARA needs your location to show nearby restaurants"
      }
    },
    "android": {
      "package": "com.hara.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDemoKeyForTesting"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#0D0B0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D0B0A",
          "dark": {
            "backgroundColor": "#0D0B0A"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow HARA to use your location to find nearby restaurants."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
